# ═══════════════════════════════════════════════════════════════
# 🤖 GitHub Education Bot — Configuration
# ═══════════════════════════════════════════════════════════════

# Production
BOT_TOKEN=your_bot_token_here # (get from BotFather)
API_ID=your_api_id_here # (get from https://my.telegram.org/apps)
API_HASH=your_api_hash_here # (get from https://my.telegram.org/apps)
BOT_USERNAME=your_bot_username_here # (without @)

# Owner / Admin
OWNER_ID=your_telegram_user_id_here # (example: 123456789)
OWNER_CONTACT_USERNAME=your_telegram_username_here # (without @)

# Must join Groups (for user verification)
REQUIRED_GROUP_1=your_required_group_1_id_here # (example: -1001234567890)
REQUIRED_GROUP_2=your_required_group_2_id_here # (example: -1001234567890)
REQUIRED_GROUP_3=your_required_group_3_id_here # (example: -1001234567890)

# Name of the required groups (for display purposes)
REQUIRED_GROUP_1_NAME=name_of_required_group_1_here # (example: Bot Updates)
REQUIRED_GROUP_2_NAME=name_of_required_group_2_here # (example: Bot Discuss)
REQUIRED_GROUP_3_NAME=name_of_required_group_3_here # (example: Bot Log)

# Invite links of the required groups (for joining purposes)
REQUIRED_GROUP_1_LINK=link_to_required_group_1_here # (example: https://t.me/jAAAAAE2aBcX1-abc123def456)
REQUIRED_GROUP_2_LINK=link_to_required_group_2_here # (example: https://t.me/AAAAAE2aBcX1-abc123def456)
REQUIRED_GROUP_3_LINK=link_to_required_group_3_here # (example: https://t.me/AAAAAE2aBcX1-abc123def456)


# Credits
CREDITS_PER_INVITE=1
DAILY_CHECKIN_CREDITS=1
INITIAL_CREDITS=0

# Default Language (en / id)
DEFAULT_LANGUAGE=en

API_SECRET=your_api_secret_here # (used for securing API endpoints, can be any random string)
HOST=0.0.0.0
PORT=3316

# QRIS Topup (AriePulsa)
ARIEPULSA_API_KEY=your_ariepulsa_api_key_here # (get from https://ariepulsa.my.id)
ARIEPULSA_API_URL=https://ariepulsa.my.id/api/qrisrealtime
ARIEPULSA_CHANNEL=QRISREALTIME
TOPUP_AUTO_CHECK_SECONDS=5
TOPUP_TIMEOUT_SECONDS=600
TOPUP_COOLDOWN_SECONDS=60
TOPUP_PACKAGES=5:8000,10:15000,25:35000,50:60000,100:100000

TOPUP_PACKAGE_BUTTON_LABEL_5=🎫 5 Credit
TOPUP_PACKAGE_BUTTON_LABEL_10=🎫 10 Credit
TOPUP_PACKAGE_BUTTON_LABEL_25=🎫 25 Credit
TOPUP_PACKAGE_BUTTON_LABEL_50=🎫 50 Credit
TOPUP_PACKAGE_BUTTON_LABEL_100=🎫 100 Credit

TOPUP_PACKAGE_PREVIEW_LABEL_5=• 🎫 5 Credit — Rp 8.000 (0.6 USDT)
TOPUP_PACKAGE_PREVIEW_LABEL_10=• 🎫 10 Credit — Rp 15.000 (1 USDT)
TOPUP_PACKAGE_PREVIEW_LABEL_25=• 🎫 25 Credit — Rp 35.000 (2 USDT)
TOPUP_PACKAGE_PREVIEW_LABEL_50=• 🎫 50 Credit — Rp 60.000 (3.5 USDT)
TOPUP_PACKAGE_PREVIEW_LABEL_100=• 🎫 100 Credit — Rp 100.000 (6 USDT)

# Manual Crypto Payment (non-otomatis)
CRYPTO_PAYMENT_MANUAL_ENABLED=1
CRYPTO_PAYMENT_BUTTON_TEXT=🌍 Bayar Luar Negeri (Crypto)
CRYPTO_PAYMENT_NOTE=Pembayaran crypto bersifat manual. Setelah transfer, kirim bukti transfer ke owner.
# Format: Network:Address,Network:Address
CRYPTO_PAYMENT_ADDRESSES=USDT BEP20:your_bep20_address_here

# ═══════════════════════════════════════════════════════════════
# Multi-School Configuration
# - public: user and owner
# - private: owner only
# ═══════════════════════════════════════════════════════════════
SCHOOL_COUNT=1 # total schools to configure (must be a number, example: 3)

SCHOOL_1_ENABLED=1 # 1 to enable, 0 to disable
SCHOOL_1_CODE=sma_negeri_1_ngawi # unique code for the school (no spaces, example: sma_negeri_1_ngawi)
SCHOOL_1_MODE=private # public or private
SCHOOL_1_NAME=SMA Negeri 1 Ngawi # full name of the school 
SCHOOL_1_GITHUB_SCHOOL_ID=123456 # unique numeric ID for GitHub Education from payload (example: 123456)
SCHOOL_1_ADDRESS=Jl Raya Suki KP 07, Ngawi, Pekalongan 12345 # full address of the school
SCHOOL_1_PHONE=(1234) 123456 # phone number of the school
SCHOOL_1_PRINCIPAL_NAME=Drs. Amba, M.Pd # name of the school principal
SCHOOL_1_PRINCIPAL_NIP=123456789 # NIP of the school principal
SCHOOL_1_CITY=Ngawi # city where the school is located
SCHOOL_1_PROVINCE=Jawa Tengah # province where the school is located
SCHOOL_1_LOGO_PATH=logo/logosekolah.png # path to the school logo
SCHOOL_1_LAT=-11.11 # latitude of the school location
SCHOOL_1_LON=123.123 # longitude of the school location

